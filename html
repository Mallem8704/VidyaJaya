    <div class="bn-item" onclick="goTo('leaderboard-screen')"><svg viewBox="0 0 24 24" fill="none" stroke="#94A3B8" stroke-width="2" stroke-linecap="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg><span class="bn-label">Ranks</span></div>
    <div class="bn-item active" onclick="goTo('profile-screen')"><svg viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg><span class="bn-label" style="color:var(--blue)">Profile</span></div>
  </nav>
</div>

<!-- ══════════════════════════════════════════════════════════
     MODALS
══════════════════════════════════════════════════════════ -->
<!-- Streak popup -->
<div class="overlay" id="streakOverlay" onclick="closeOverlay('streakOverlay')">
  <div class="modal" onclick="event.stopPropagation()">
    <button class="modal-close" onclick="closeOverlay('streakOverlay')">✕</button>
    <span class="streak-modal-fire">🔥</span>
    <div class="modal-title">Streak Maintained!</div>
    <div class="modal-sub">You're on a <strong>12-day streak!</strong><br>Keep going to unlock the 15-day badge 🏅</div>
    <div class="modal-coins">💰 +15 Coins</div>
    <div style="background:var(--orange-l);border-radius:var(--r12);padding:12px;font-size:13px;color:var(--orange-d);margin-bottom:20px">3 more days to unlock <strong>Streak Master</strong> badge!</div>
    <button class="btn btn-orange btn-full" onclick="closeOverlay('streakOverlay');goTo('test')">Start Today's Test →</button>
  </div>
</div>

<!-- Coin popup -->
<div class="overlay" id="coinOverlay" onclick="closeOverlay('coinOverlay')">
  <div class="modal" onclick="event.stopPropagation()">
    <button class="modal-close" onclick="closeOverlay('coinOverlay')">✕</button>
    <div style="font-size:56px;margin-bottom:8px">💰</div>
    <div class="modal-title">Coin Balance</div>
    <div class="modal-coins" id="modalCoinBal">340 Coins</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px;text-align:left">
      <div style="background:var(--green-l);border-radius:var(--r12);padding:12px">
        <div style="font-size:12px;font-weight:700;color:var(--green-d);margin-bottom:2px">EARNED</div>
        <div style="font-size:20px;font-weight:900;color:var(--green)">+420</div>
        <div style="font-size:11px;color:var(--muted)">this month</div>
      </div>
      <div style="background:#FEE2E2;border-radius:var(--r12);padding:12px">
        <div style="font-size:12px;font-weight:700;color:var(--red);margin-bottom:2px">SPENT</div>
        <div style="font-size:20px;font-weight:900;color:var(--red)">-80</div>
        <div style="font-size:11px;color:var(--muted)">this month</div>
      </div>
    </div>
    <button class="btn btn-primary btn-full" onclick="closeOverlay('coinOverlay');goTo('pricing-screen')">Redeem / Upgrade →</button>
  </div>
</div>

<script>
// ══════════════════════════════════════════════════
//  NAVIGATION
// ══════════════════════════════════════════════════
let history2 = ['landing'];

function goTo(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const next = document.getElementById(id);
  if (next) { next.classList.add('active'); next.scrollTop = 0; }
  history2.push(id);
  window.scrollTo(0, 0);
  // Trigger reveal
  setTimeout(initReveal, 100);
}

function goBack() {
  if (history2.length > 1) { history2.pop(); goTo(history2[history2.length - 1]); }
}

function scrollTo2(id) {
  const el = document.getElementById(id);
  if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

// ══════════════════════════════════════════════════
//  SCROLL EFFECTS
// ══════════════════════════════════════════════════
window.addEventListener('scroll', () => {
  const nav = document.getElementById('navbar');
  if (nav) nav.classList.toggle('scrolled', window.scrollY > 50);
  initReveal();
});

function initReveal() {
  document.querySelectorAll('.reveal').forEach(el => {
    const rect = el.getBoundingClientRect();
    if (rect.top < window.innerHeight - 60) el.classList.add('visible');
  });
}

setTimeout(initReveal, 200);

// ══════════════════════════════════════════════════
//  AUTH
// ══════════════════════════════════════════════════
function switchAuthTab(tab) {
  document.getElementById('loginTab').classList.toggle('active', tab === 'login');
  document.getElementById('signupTab').classList.toggle('active', tab === 'signup');
  document.getElementById('loginForm').style.display = tab === 'login' ? 'block' : 'none';
  document.getElementById('signupForm').style.display = tab === 'signup' ? 'block' : 'none';
}

function doLogin() {
  showStreakPopup();
  setTimeout(() => { goTo('dashboard'); }, 200);
}

// ══════════════════════════════════════════════════
//  QUIZ ENGINE
// ══════════════════════════════════════════════════
const QUESTIONS = [
  { cat:'POLITY', q:'Which article guarantees Right to Constitutional Remedies?', opts:['Article 14','Article 19','Article 32','Article 44'], ans:2 },
  { cat:'HISTORY', q:'The Battle of Plassey was fought in which year?', opts:['1757','1764','1775','1803'], ans:0 },
  { cat:'GEOGRAPHY', q:'Which river forms the boundary between India and Bangladesh for the longest stretch?', opts:['Brahmaputra','Ganga','Padma','Barak'], ans:2 },
  { cat:'ECONOMY', q:'Which organisation is called the "Banker of Banks" in India?', opts:['SBI','HDFC','Reserve Bank of India','NABARD'], ans:2 },
  { cat:'SCIENCE', q:'What is the chemical symbol for Gold?', opts:['Go','Gl','Gd','Au'], ans:3 },
  { cat:'POLITY', q:'Which part of the Constitution deals with Fundamental Rights?', opts:['Part II','Part III','Part IV','Part V'], ans:1 },
  { cat:'CURRENT AFFAIRS', q:'India\'s Chandrayaan-3 landed near which pole of the Moon?', opts:['North Pole','South Pole','Equatorial','Far Side'], ans:1 },
  { cat:'REASONING', q:'If APPLE = 50, MANGO = 52, then BANANA = ?', opts:['42','44','46','48'], ans:2 },
  { cat:'APTITUDE', q:'A train 120m long passes a pole in 12 seconds. Speed is?', opts:['8 m/s','10 m/s','12 m/s','15 m/s'], ans:1 },
  { cat:'ECONOMY', q:'GST in India was implemented from which date?', opts:['April 1, 2017','July 1, 2017','Jan 1, 2018','Oct 1, 2017'], ans:1 },
];

let curQ = 0, selected = [], timerVal = 30, timerInterval2 = null;
const LETTERS = ['A','B','C','D'];

function initTest() {
  curQ = 0;
  selected = new Array(QUESTIONS.length).fill(-1);
  // Build dots
  const dots = document.getElementById('questionDots');
  dots.innerHTML = QUESTIONS.map((_, i) => `<div class="q-dot${i===0?' current':''}" id="dot${i}" onclick="jumpQ(${i})">${i+1}</div>`).join('');
  renderQuestion();
  startTimer();
}

function renderQuestion() {
  const q = QUESTIONS[curQ];
  document.getElementById('testSubject').textContent = q.cat;
  document.getElementById('testQNum').textContent = `Question ${curQ+1} of ${QUESTIONS.length}`;
  document.getElementById('qCategory').textContent = q.cat;
  document.getElementById('qText').textContent = q.q;
  document.getElementById('testProgressBar').style.width = ((curQ+1)/QUESTIONS.length*100)+'%';
  // Dots
  QUESTIONS.forEach((_,i)=>{
    const d=document.getElementById('dot'+i);
    if(d){d.className='q-dot'+(selected[i]>=0?' answered':'')+(i===curQ?' current':'');};
  });
  // Options
  const ol = document.getElementById('optionsList');
  ol.innerHTML = q.opts.map((opt, i) => `
    <button class="option-btn${selected[curQ]===i?' selected':''}" onclick="selectOpt(${i})">
      <div class="option-letter">${LETTERS[i]}</div>
      <span class="option-text">${opt}</span>
    </button>`).join('');
  // Buttons
  document.getElementById('prevBtn').style.opacity = curQ===0?'0.4':'1';
  document.getElementById('nextBtn').style.display = curQ<QUESTIONS.length-1?'flex':'none';
  document.getElementById('submitBtn').style.display = curQ===QUESTIONS.length-1?'flex':'none';
  // Reset timer
  clearInterval(timerInterval2);
  timerVal = 30;
  updateTimerDisplay();
  startTimer();
}

function selectOpt(idx) {
  selected[curQ] = idx;
  renderQuestion();
}

function prevQuestion() { if(curQ>0){curQ--;renderQuestion();} }
function nextQuestion() { if(curQ<QUESTIONS.length-1){curQ++;renderQuestion();} }
function jumpQ(i) { curQ=i; renderQuestion(); }

function startTimer() {
  timerInterval2 = setInterval(() => {
    timerVal--;
    updateTimerDisplay();
    if (timerVal <= 0) { clearInterval(timerInterval2); if(curQ<QUESTIONS.length-1)nextQuestion(); else submitTest(); }
  }, 1000);
}

function updateTimerDisplay() {
  const d = document.getElementById('timerDisplay');
  const c = document.getElementById('timerCircle');
  if (!d) return;
  d.textContent = timerVal;
  d.className = 'timer-text' + (timerVal<=10?' urgent':'');
  const full = 138.2;
  c.style.strokeDashoffset = full - (full * timerVal / 30);
  c.style.stroke = timerVal <= 10 ? '#EF4444' : timerVal <= 20 ? '#F59E0B' : '#2563EB';
}

function submitTest() {
  clearInterval(timerInterval2);
  const correct = selected.filter((s, i) => s === QUESTIONS[i].ans).length;
  const total = QUESTIONS.length;
  const pct = Math.round(correct/total*100);
  const wrong = selected.filter((s,i)=>s>=0&&s!==QUESTIONS[i].ans).length;
  document.getElementById('resultScore').textContent = correct;
  document.getElementById('resultTotal').textContent = '/ '+total;
  document.getElementById('rsAccuracy').textContent = pct+'%';
  document.getElementById('cbCorrect').textContent = correct;
  document.getElementById('cbWrong').textContent = wrong;
  document.getElementById('cbSkip').textContent = total-correct-wrong;
  document.getElementById('barCorrect').style.height = Math.max(10,correct*4)+'px';
  document.getElementById('barWrong').style.height = Math.max(4,wrong*4)+'px';
  const msgs = pct>=90?['Exceptional! 🏆','You\'re in top 5% today']:pct>=70?['Excellent! 🎉','You\'re in top 15% today']:pct>=50?['Good job! 👍','Keep practising!']:['Keep going! 💪','Review weak areas'];
  document.getElementById('resultTitle').textContent = msgs[0];
  document.getElementById('resultSub').textContent = msgs[1];
  const coins = Math.max(5, Math.round(pct/10)*2);
  // Show coin float animation
  spawnCoins();
  showStreakPopup2();
  goTo('result');
  setTimeout(initReveal,200);
}

function spawnCoins() {
  for(let i=0;i<5;i++){
    const el=document.createElement('div');
    el.className='coin-float';
    el.textContent='💰';
    el.style.left=Math.random()*80+10+'vw';
    el.style.top='60vh';
    el.style.animationDelay=(i*0.15)+'s';
    document.body.appendChild(el);
    setTimeout(()=>el.remove(),2000);
  }
}

// ══════════════════════════════════════════════════
//  MODALS
// ══════════════════════════════════════════════════
function showStreakPopup() { document.getElementById('streakOverlay').classList.add('open'); }
function showStreakPopup2() { setTimeout(()=>document.getElementById('streakOverlay').classList.add('open'),600); }
function showCoinPopup() { document.getElementById('coinOverlay').classList.add('open'); }
function closeOverlay(id) { document.getElementById(id).classList.remove('open'); }

// ══════════════════════════════════════════════════
//  LEADERBOARD TABS
// ══════════════════════════════════════════════════
function setLbTab(el, type) {
  document.querySelectorAll('.lb-tab').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  const pool = {daily:'₹2,940',weekly:'₹19,600',streak:'₹8,200'}[type];
  document.querySelector('.lb-full-header + div + div .rpb-val, [style*="₹"]') && null;
}

// ══════════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════════
document.addEventListener('DOMContentLoaded', () => {
  initTest();
  initReveal();
  // Re-init test when navigating to test screen
  document.querySelectorAll('[onclick*="goTo(\'test\')"]').forEach(btn=>{
    btn.addEventListener('click',()=>setTimeout(initTest,100));
  });
});

// Re-init when test screen becomes active
const testObs = new MutationObserver((muts) => {
  muts.forEach(m => {
    if(m.target.id==='test' && m.target.classList.contains('active')) { initTest(); }
  });
});
const testEl = document.getElementById('test');
if(testEl) testObs.observe(testEl, { attributes: true, attributeFilter: ['class'] });
</script>
</body>
</html>

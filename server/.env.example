# Server configuration
PORT=5000

# Supabase Configuration
# You can get these from your Supabase Project Settings -> API
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
RAZORPAYX_ACCOUNT_NUMBER=232323...

# Fast2SMS OTP Configuration (Indian SMS Gateway)
# Sign up at https://www.fast2sms.com/ to get your API key
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Email Configuration (Nodemailer for welcome emails etc.)
# If using Gmail, use an App Password instead of your real password
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Frontend URL (Used for CORS and redirect links)
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── Instagram Automation ─────────────────────────────────────────────────────
# Get these from the Meta Developer Dashboard: https://developers.facebook.com/
#
# 1. META_APP_ID         — Your Facebook App ID (found in App Settings > Basic)
# 2. META_APP_SECRET     — Your Facebook App Secret (same location)
# 3. INSTAGRAM_BUSINESS_ACCOUNT_ID — Your Instagram Business Account numeric ID
#    (Call GET /me/accounts → find your page → GET /{page_id}?fields=instagram_business_account)
# 4. INSTAGRAM_ACCESS_TOKEN — Long-lived token (60 days, auto-refreshed weekly by the cron)
#    Run: node server/scripts/setupInstagram.js  to generate and validate this.
#
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_ig_business_account_id
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token

# Admin endpoint secret (used to protect /api/admin/instagram/* routes)
ADMIN_SECRET=vidyajaya-admin
